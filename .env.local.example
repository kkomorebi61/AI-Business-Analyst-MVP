# ============================================================
# AI Business Analyst —— 环境变量示例
# 复制为 .env.local 并填入真实值。Sprint 1 使用规则引擎 + Mock，无需任何 Key。
# ============================================================

# Agent 执行模式：rule（默认，规则引擎+Mock）| glm（调用 GLM 5.1）
ANALYST_AGENT_MODE=rule

# GLM 5.1 接入（仅在 ANALYST_AGENT_MODE=glm 时需要）—— Sprint 2+ 启用
# 智谱 BigModel：https://open.bigmodel.cn/
ANALYST_LLM_API_KEY=
ANALYST_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ANALYST_LLM_MODEL=glm-5.1
